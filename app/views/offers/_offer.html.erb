<!-- app/views/offers/_offer.html.erb -->
<div id="<%= dom_id offer %>" class="offer-card w-full sm:w-auto my-5 p-4 border rounded-lg">
  <p><strong>Item:</strong> <%= offer.item.item_name %></p>
  <p><strong>Offered item:</strong> <%= offer.offered_item_text %></p>
  <p><strong>Status:</strong> <%= offer.status %></p>
  <p><strong>Accepted at:</strong> <%= offer.accepted_at.presence || '—' %></p>

  <div class="actions mt-3 space-x-2">
    <%= link_to "Show", offer, class: "px-3 py-1 bg-gray-100 rounded" %>

    <% if offer.item.user_id == current_user.id %>
      <%= link_to "Edit", edit_offer_path(offer), class: "px-3 py-1 bg-blue-100 rounded" %>
    <% end %>

    <%= button_to "Destroy", offer,
          method: :delete,
          data: { turbo_confirm: "Are you sure?" },
          class: "px-3 py-1 bg-red-100 rounded" %>
  </div>
</div>
