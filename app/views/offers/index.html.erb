<% content_for :title, "Offers" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">提案一覧</h1>
    
  </div>

<div id="offers" class="min-w-full divide-y divide-gray-200 space-y-5">
  <% if @offers.any? %>
    <% @offers.each do |offer| %>
      <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
        <%= render offer %>

    
      </div>
    <% end %>
  <% else %>
    <p class="text-center my-10">No offers found.</p>
  <% end %>
</div>
