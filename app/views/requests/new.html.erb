<h1>新しい募集を作成</h1>

<%= form_with model: @request, local: true do |f| %>
  <div>
    <%= f.label :title, "タイトル" %><br>
    <%= f.text_field :title %>
  </div>
  <div>
    <%= f.label :description, "詳細" %><br>
    <%= f.text_area :description %>
  </div>
  <%= f.submit "募集する", class: "btn btn-primary" %>
<% end %>
