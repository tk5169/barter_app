<%# app/views/items/edit.html.erb %>
<% content_for :title, "アイテムを編集する" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl mb-4">Editing item</h1>

  <!-- フォーム本体 -->
  <%= render "form", item: @item %>

  <!-- 編集画面に「削除」リンクを移動 -->
  <div class="mt-6">
    <%= link_to "このアイテムを削除する", confirm_destroy_item_path(@item),
                class: "px-4 py-2 bg-red-600 text-white rounded" %>
  </div>

  <!-- 詳細・一覧へのリンク -->
  <div class="mt-4 space-x-4">
    <%= link_to "このアイテムを見る", item_path(@item),
                class: "px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-800 rounded" %>
    <%= link_to "アイテム一覧に戻る", items_path,
                class: "px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-800 rounded" %>
  </div>
</div>
